# Copy to .env for local runs (never commit .env).

GEMINI_API_KEY=

# Ordered Gemini model fallback list (comma-separated). Tries each model in order;
# falls back when a model's daily free-tier quota is exhausted. Defaults in code if unset.
# GEMINI_MODELS=gemini-3-flash-preview,gemini-2.5-flash

# Legacy single-model override (used only when GEMINI_MODELS is unset).
# GEMINI_MODEL=gemini-2.5-flash

# Gmail: IMAP read + email delivery via app password.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Optional: ElevenLabs TTS for MP3 audio on daily briefing emails
ELEVENLABS_API_KEY=

# Optional: override email recipient (defaults to GMAIL_ADDRESS).
# BRIEFING_TO_EMAIL=

# Optional: delivery method when recipient differs from sender (auto uses IMAP for self-send).
# BRIEFING_DELIVERY=imap   # append to INBOX (default for self-send; avoids Sent-only)
# BRIEFING_DELIVERY=smtp   # force SMTP (e.g. BRIEFING_TO_EMAIL=other@gmail.com)

# Optional: hours of inbox lookback for newsletter briefings (default 24).
# BRIEFING_LOOKBACK_HOURS=24

# Optional: pin NPR calendar week for testing (ISO date or datetime).
# SUMMARY_WEEK_REFERENCE=
